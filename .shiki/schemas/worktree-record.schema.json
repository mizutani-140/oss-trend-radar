{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shiki.local/schemas/worktree-record.schema.json",
  "title": "Shiki Worktree Record",
  "type": "object",
  "required": [
    "task_id",
    "goal_id",
    "branch",
    "path",
    "runtime",
    "state",
    "locks",
    "created_by",
    "created_at",
    "pr"
  ],
  "properties": {
    "task_id": { "type": "string", "pattern": "^T-[0-9]{4,}$" },
    "goal_id": { "type": "string", "pattern": "^G-[0-9]{4,}$" },
    "branch": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "runtime": { "type": "string" },
    "state": {
      "enum": [
        "planned",
        "registered",
        "active",
        "pr-open",
        "frozen",
        "merged",
        "abandoned",
        "archived",
        "removed"
      ]
    },
    "locks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "pr": { "type": ["integer", "null"] }
  },
  "additionalProperties": true
}
